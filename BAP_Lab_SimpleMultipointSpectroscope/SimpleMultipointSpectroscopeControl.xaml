<UserControl x:Class="LightFieldAddInSamples.BAP_Lab_SimpleMultipointSpectroscope.SimpleMultipointSpectroscopeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1106.5">

    <Grid>
        <TabControl Name="MainTabControl" Margin="4">
            <!-- ======================================================= -->
            <!-- TAB 1: SETUP                                            -->
            <!-- ======================================================= -->
            <TabItem Header="Setup">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid Margin="8" HorizontalAlignment="Left" MinWidth="1080">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="720"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <!-- Image Acquisition -->
                            <GroupBox Header="Image Acquisition" Margin="0,0,0,8">
                                <StackPanel Margin="4">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Content="Settings Managed by LightField Experiment Panel" Foreground="Gray" FontStyle="Italic" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Name="TestAcquireButton" Content="Test Acquire Image" Height="28" Width="150" Click="TestAcquireButton_Click" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Border BorderBrush="Gray" BorderThickness="1" Background="Black" Height="150" Margin="0,8,0,0">
                                        <Image Name="SetupImageControl" Stretch="Uniform"/>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <!-- Manual Movement -->
                            <GroupBox Header="Manual Move" Margin="0,0,0,8">
                                <StackPanel Margin="4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                        <Label Content="Feed Rate:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Name="MoveFeedRate" Text="3000" Width="60" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    </StackPanel>

                                    <Grid HorizontalAlignment="Left" Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="45"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="20"/>
                                            <!-- Spacer -->
                                            <ColumnDefinition Width="40"/>
                                            <!-- Z buttons -->
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="130"/>
                                            <!-- Hot Region -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Y Axis Positive -->
                                        <Button Grid.Row="0" Grid.Column="3" Content="Y+++" Click="MoveBtn_Click" Tag="Y3" Width="38" Height="30" />
                                        <Button Grid.Row="1" Grid.Column="3" Content="Y++" Click="MoveBtn_Click" Tag="Y2" Width="38" Height="30" />
                                        <Button Grid.Row="2" Grid.Column="3" Content="Y+" Click="MoveBtn_Click" Tag="Y1" Width="38" Height="30" />

                                        <!-- Increment Adjustors (Rank 1, 2, 3) -->
                                        <TextBox   Name="StepSize3" Grid.Column="6" Text="1.0" Width="38" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="Coarse Step Size"/>
                                        <TextBox   Name="StepSize2" Grid.Row="1" Grid.Column="5" Text="0.1" Width="38" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="Mid Step Size"/>
                                        <TextBox   Name="StepSize1" Grid.Row="2" Grid.Column="4" Text="0.01" Width="38" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="Fine Step Size"/>

                                        <!-- Horizontal Axis -->
                                        <Button Grid.Row="3" Grid.Column="0" Content="X---" Click="MoveBtn_Click" Tag="X-3" Width="38" Height="38" />
                                        <Button Grid.Row="3" Grid.Column="1" Content="X--" Click="MoveBtn_Click" Tag="X-2" Width="38" Height="38" />
                                        <Button Grid.Row="3" Grid.Column="2" Content="X-" Click="MoveBtn_Click" Tag="X-1" Width="38" Height="38" />

                                        <Button Grid.Row="3" Grid.Column="3" Content="Set Origin" Width="90" Height="40" Click="SetOrigin_Click"/>

                                        <Button Grid.Row="3" Grid.Column="4" Content="X+" Click="MoveBtn_Click" Tag="X1" Width="38" Height="38" />
                                        <Button Grid.Row="3" Grid.Column="5" Content="X++" Click="MoveBtn_Click" Tag="X2" Width="38" Height="38" />
                                        <Button Grid.Row="3" Grid.Column="6" Content="X+++" Click="MoveBtn_Click" Tag="X3" Width="38" Height="38" />

                                        <!-- Reference Labels (Negative side, mirroring TBs) -->
                                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding ElementName=StepSize1, Path=Text}" Foreground="Gray" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,13,0,0"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ElementName=StepSize2, Path=Text}" Foreground="Gray" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,13,0,0"/>
                                        <TextBlock Grid.Row="6" Text="{Binding ElementName=StepSize3, Path=Text}" Foreground="Gray" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,13,0,0"/>

                                        <!-- Y Axis Negative -->
                                        <Button Grid.Row="4" Grid.Column="3" Content="Y-" Click="MoveBtn_Click" Tag="Y-1" Width="38" Height="30" />
                                        <Button Grid.Row="5" Grid.Column="3" Content="Y--" Click="MoveBtn_Click" Tag="Y-2" Width="38" Height="30" />
                                        <Button Grid.Row="6" Grid.Column="3" Content="Y---" Click="MoveBtn_Click" Tag="Y-3" Width="38" Height="30" />

                                        <!-- Z Axis -->
                                        <Button Grid.Row="0" Grid.Column="8" Content="Z+++" Click="MoveBtn_Click" Tag="Z3" Width="38" Height="30" />
                                        <Button Grid.Row="1" Grid.Column="8" Content="Z++" Click="MoveBtn_Click" Tag="Z2" Width="38" Height="30" />
                                        <Button Grid.Row="2" Grid.Column="8" Content="Z+" Click="MoveBtn_Click" Tag="Z1" Width="38" Height="30" />
                                        <Button Grid.Row="4" Grid.Column="8" Content="Z-" Click="MoveBtn_Click" Tag="Z-1" Width="38" Height="30" />
                                        <Button Grid.Row="5" Grid.Column="8" Content="Z--" Click="MoveBtn_Click" Tag="Z-2" Width="38" Height="30" />
                                        <Button Grid.Row="6" Grid.Column="8" Content="Z---" Click="MoveBtn_Click" Tag="Z-3" Width="38" Height="30" />

                                        <!-- Z Increment Adjustors (Rank 1, 2, 3) -->
                                        <TextBox   Name="ZStepSize3" Grid.Row="0" Grid.Column="9" Text="1.0" Width="38" Height="22" VerticalAlignment="Top" HorizontalAlignment="Center" ToolTip="Z Coarse" Margin="0,8,0,0"/>
                                        <TextBox   Name="ZStepSize2" Grid.Row="1" Grid.Column="9" Text="0.1" Width="38" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="Z Mid"/>
                                        <TextBox   Name="ZStepSize1" Grid.Row="2" Grid.Column="9" Text="0.01" Width="38" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="Z Fine"/>

                                        <!-- Z Reference Labels (Negative side, mirroring Z TBs) -->
                                        <TextBlock Grid.Row="4" Grid.Column="9" Text="{Binding ElementName=ZStepSize1, Path=Text}" Foreground="Gray" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="5" Grid.Column="9" Text="{Binding ElementName=ZStepSize2, Path=Text}" Foreground="Gray" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12,0,0,10"/>
                                        <TextBlock Grid.Row="6" Grid.Column="9" Text="{Binding ElementName=ZStepSize3, Path=Text}" Foreground="Gray" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12,0,0,10"/>

                                        <!-- Keyboard Hot Region -->
                                        <Border Grid.Column="10" Grid.Row="0" Grid.RowSpan="7" 
                                                Name="KeyboardHotRegion" 
                                                BorderBrush="DarkGray" BorderThickness="1"
                                                Margin="10,0,0,0" CornerRadius="4"
                                                MouseEnter="HotRegion_MouseEnter" MouseLeave="HotRegion_MouseLeave"
                                                Background="Transparent">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Label Content="⌨ Keyboard" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBlock Name="HotRegionStatus" Text="Hover to activate" 
                                                           FontSize="9" TextAlignment="Center" Foreground="Gray" Margin="5" TextWrapping="Wrap"/>
                                                <TextBlock Text="Arrows (XY)&#x0a;PgUp/Dn (Z)&#x0a;[Ctrl] for Fine" 
                                                           FontSize="8" TextAlignment="Center" Foreground="#888" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>

                        <!-- RIGHT COLUMN -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <!-- Serial Port -->
                            <GroupBox Header="Serial Port (Stage Controller)" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="85"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="COM Port:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" Name="PortCombo" Margin="4" IsReadOnly="True"/>
                                    <Button Grid.Row="0" Grid.Column="2" Name="RefreshPortsButton" Content="Refresh" Margin="0,4,0,4" Click="RefreshPorts_Click"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="Baud Rate:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" Name="BaudCombo" Margin="4,2,4,2">
                                        <ComboBoxItem Content="9600"/>
                                        <ComboBoxItem Content="19200"/>
                                        <ComboBoxItem Content="38400"/>
                                        <ComboBoxItem Content="57600"/>
                                        <ComboBoxItem Content="115200"/>
                                        <ComboBoxItem IsSelected="True" Content="250000"/>
                                    </ComboBox>

                                    <Button Grid.Row="1" Grid.Column="2" Name="ConnectButton" Content="Connect" Margin="0,2,0,2" Click="ConnectButton_Click"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Name="SerialStatusText" Text="Status: disconnected" Foreground="Gray" Margin="4,6,4,2"/>

                                    <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Name="ManualCommandBox" Margin="0,0,4,0" KeyDown="ManualCommandBox_KeyDown"/>
                                        <Button Grid.Column="1" Name="SendCmdButton" Content="Send" Click="SendCmdButton_Click"/>
                                    </Grid>
                                </Grid>
                            </GroupBox>

                            <!-- Terminal -->
                            <GroupBox Header="Terminal Log" Margin="0,0,0,8">
                                <TextBox Name="TerminalText" Height="100" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" Margin="4"/>
                            </GroupBox>

                            <!-- Coordinates & Homing -->
                            <GroupBox Header="Coordinates &amp; Homing" Margin="0,0,0,8">
                                <StackPanel Margin="4">
                                    <WrapPanel Margin="0,0,0,4">
                                        <Button Content="Home XY (G28 X Y)" Width="120" Margin="0,0,4,4" Click="HomeXY_Click"/>
                                        <Button Content="Home Z (G28 Z)" Width="110" Margin="0,0,4,4" Click="HomeZ_Click"/>
                                        <Button Content="Save EEPROM (M500)" Width="130" Margin="0,0,4,4" Click="SaveEEPROM_Click"/>
                                    </WrapPanel>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Current Pos:" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Name="CurrentPosText" Text="X: 0.00  Y: 0.00  Z: 0.00" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ======================================================= -->
            <!-- TAB 2: PROCESS                                          -->
            <!-- ======================================================= -->
            <TabItem Header="Process">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid Margin="8" HorizontalAlignment="Left" MinWidth="700">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <!-- Grid Configuration -->
                            <GroupBox Header="Grid Configuration" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="X Points:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Name="GridXPoints" Text="3" Margin="0,2,0,2"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="Y Points:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Name="GridYPoints" Text="3" Margin="0,2,0,2"/>

                                    <Label Grid.Row="2" Grid.Column="0" Content="X Step (mm):" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Name="GridXStep" Text="1.0" Margin="0,2,0,2"/>

                                    <Label Grid.Row="3" Grid.Column="0" Content="Y Step (mm):" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Name="GridYStep" Text="1.0" Margin="0,2,0,2"/>

                                    <Label Grid.Row="4" Grid.Column="0" Content="Dwell (ms):" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Name="GridDwellMs" Text="500" Margin="0,2,0,2"/>

                                    <Label Grid.Row="5" Grid.Column="0" Content="Pattern:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="5" Grid.Column="1" Name="GridPatternCombo" Margin="0,2,0,2">
                                        <ComboBoxItem IsSelected="True" Content="Row-by-Row"/>
                                        <ComboBoxItem Content="Column-by-Column"/>
                                        <ComboBoxItem Content="Serpentine Row"/>
                                        <ComboBoxItem Content="Serpentine Column"/>
                                    </ComboBox>

                                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,2">
                                        <CheckBox Name="StaggeredCheck" Content="Staggered Grid" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>

                                    <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Name="LoadGridButton" Content="Load JSON" Margin="0,0,2,0" Height="26" Click="LoadGridButton_Click"/>
                                        <Button Grid.Column="1" Name="SaveGridButton" Content="Save JSON" Margin="2,0,2,0" Height="26" Click="SaveGridButton_Click"/>
                                        <Button Grid.Column="2" Name="GeneratePatternButton" Content="Generate" Margin="2,0,0,0" Height="26" Click="GeneratePatternButton_Click"/>
                                    </Grid>
                                </Grid>
                            </GroupBox>
                        </StackPanel>

                        <!-- MIDDLE COLUMN -->
                        <StackPanel Grid.Column="1" Margin="8,0,8,0">
                            <!-- Interactive Grid View -->
                            <GroupBox Header="Interactive Grid View" Margin="0,0,0,8">
                                <StackPanel Margin="4">
                                    <Border BorderBrush="Gray" BorderThickness="1" Background="#FFF5F5F5" Height="200" Width="200" HorizontalAlignment="Left" ClipToBounds="True">
                                        <Canvas Name="GridCanvas" Width="200" Height="200" Background="Transparent" MouseLeftButtonDown="GridCanvas_MouseLeftButtonDown" MouseMove="GridCanvas_MouseMove"/>
                                    </Border>
                                    <TextBlock Name="CanvasStatusText" Text="Hover over a point..." Margin="0,4,0,0" Foreground="Gray" FontStyle="Italic"/>
                                    <TextBlock Text="Click a point to move the stage to that coordinate." Margin="0,2,0,0" Foreground="Gray"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Grid Points Editor -->
                            <GroupBox Header="Grid Points Editor" Margin="0,0,0,8">
                                <StackPanel Margin="4">
                                    <DataGrid Name="GridPointsDataGrid" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True" Height="240" Margin="0,0,0,4"
                                              Background="#2D2D30" RowBackground="#2D2D30" AlternatingRowBackground="#3E3E42" Foreground="White" 
                                              BorderBrush="#555" GridLinesVisibility="All" HorizontalGridLinesBrush="#555" VerticalGridLinesBrush="#555">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#1E1E1E"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#555"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                                <Setter Property="Padding" Value="4"/>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Idx" Binding="{Binding Index, Mode=OneWay}" IsReadOnly="True" Width="40" />
                                            <DataGridTextColumn Header="X (mm)" Binding="{Binding X}" Width="70" />
                                            <DataGridTextColumn Header="Y (mm)" Binding="{Binding Y}" Width="70" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Text="Tip: Edit coordinates, add rows, or delete rows. The Canvas below will auto-update." FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>

                        <!-- RIGHT COLUMN -->
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <!-- Scan Control -->
                            <GroupBox Header="Scan Control" Margin="0,0,0,8">
                                <StackPanel Margin="4">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Name="StartScanButton" Content="Start Scan" Height="30" Margin="0,0,4,0" Click="StartScanButton_Click" Background="LightGreen"/>
                                        <Button Grid.Column="1" Name="StopScanButton" Content="Stop Scan" Height="30" Margin="4,0,0,0" IsEnabled="False" Click="StopScanButton_Click" Background="LightCoral"/>
                                    </Grid>
                                    <ProgressBar Name="ScanProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
                                    <TextBlock Name="ScanStatusText" Text="Ready" Margin="0,4,0,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Live Image View -->
                            <GroupBox Header="Live Image Check" Margin="0,0,0,8" VerticalAlignment="Stretch">
                                <StackPanel Margin="4">
                                    <Border BorderBrush="Gray" BorderThickness="1" Background="Black" Height="150" HorizontalAlignment="Stretch">
                                        <Image Name="LiveImageControl" Stretch="Uniform"/>
                                    </Border>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ======================================================= -->
            <!-- TAB 3: EXPORT                                           -->
            <!-- ======================================================= -->
            <TabItem Header="Export">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8" Width="360" HorizontalAlignment="Left">

                        <!-- Output Folder -->
                        <GroupBox Header="Output Folder" Margin="0,0,0,8">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Name="OutputFolderText" Margin="0,0,4,0" VerticalAlignment="Center" IsReadOnly="True" />
                                <Button Grid.Column="1" Name="BrowseFolderButton" Content="Browse..." Click="BrowseFolderButton_Click"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Export Actions" Margin="0,0,0,8">
                            <StackPanel Margin="4">
                                <Button Name="ExportBothButton" Content="Export PNGs &amp; JSON" Height="30" Margin="0,0,0,8" Click="ExportBothButton_Click"/>
                                <TextBlock Name="ExportStatusText" Text="Wait for scan to complete." Foreground="Gray"/>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
